# ══════════════════════════════════════════════════════
# CineReview — Environment Variable Template
# Salin file ini menjadi .env dan isi nilainya.
# JANGAN commit file .env ke GitHub!
# ══════════════════════════════════════════════════════

# Flask secret key (generate dengan: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=your-secret-key-here

# Mode debug (gunakan "false" di production/Vercel)
FLASK_DEBUG=false
